FROM python:3.10-slim

WORKDIR /app

# Install only what training needs
RUN pip install --no-cache-dir \
    scikit-learn==1.3.2 \
    joblib==1.3.2 \
    numpy==1.26.4 \
    mlflow==2.11.3

COPY train_mlflow.py .
COPY model.joblib .

RUN mkdir -p /app/model

# Train, log to MLflow, copy model to the shared volume
CMD ["sh", "-c", "python train_mlflow.py && cp model.joblib /app/model/model.joblib"]
